{
  "name": "markdown-editor",
  "version": "1.7.0",
  "description": "A professional markdown editor with syntactic tree parsing and WYSIWYG editing",
  "main": "src/electron/main.js",
  "type": "module",
  "scripts": {
    "build": "npm run lint && electron-builder --publish never && node scripts/clean-dist.js",
    "cleanup": "rm -rf test-results",
    "docs": "node scripts/generate-api-docs.js",
    "dist:linux": "electron-builder --linux --publish never && node scripts/clean-dist.js",
    "dist:mac": "electron-builder --mac --publish never && node scripts/clean-dist.js",
    "dist:win": "electron-builder --win --publish never && node scripts/clean-dist.js",
    "lint": "npm run lint:codestyle && npm run lint:format && npm run lint:typing && npm run lint:codestyle",
    "lint:codestyle": "npm run lint:comments && npm run lint:quotes",
    "lint:comments": "node scripts/lint-comments.js",
    "lint:format": "biome format --write src test scripts",
    "lint:quotes": "eslint --fix -c backticks.config.js",
    "lint:typing": "tsc -p jsconfig.json",
    "postinstall": "playwright install firefox --with-deps && electron-builder install-app-deps",
    "start": "electron .",
    "test": "npm run lint && npm run test:unit && npm run test:integration && npm run test:cleanup",
    "test:cleanup": "rm -rf test-results",
    "test:unit": "node --test \"test/unit/**/*.test.js\"",
    "test:integration": "playwright test"
  },
  "keywords": [
    "markdown",
    "editor",
    "electron",
    "wysiwyg"
  ],
  "author": "",
  "license": "CC0-1.0",
  "devDependencies": {
    "@biomejs/biome": "^1.5.0",
    "@electron/rebuild": "^4.0.3",
    "@playwright/test": "^1.40.0",
    "electron": "^40.2.1",
    "electron-builder": "^26.7.0",
    "eslint": "^10.0.3",
    "jsdom": "^28.1.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "fastest-levenshtein": "^1.0.16",
    "lucide-static": "^0.563.0"
  },
  "overrides": {
    "ajv": "^6.14.0",
    "minimatch": "^10.2.4",
    "tar": "^7.5.8"
  },
  "engines": {
    "node": ">=22"
  },
  "build": {
    "appId": "com.pomax.markdown-editor",
    "productName": "Markdown Editor",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "!src/**/*.d.ts"
    ],
    "win": {
      "target": "portable",
      "icon": null
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": "AppImage",
      "category": "Office"
    },
    "asar": true,
    "npmRebuild": true,
    "removePackageScripts": true
  }
}
