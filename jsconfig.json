{
    "compilerOptions": {
        "checkJs": true,
        "allowJs": true,
        "module": "ESNext",
        "moduleResolution": "node",
        "target": "ESNext",
        "strict": true,
        "strictPropertyInitialization": false,
        "noEmit": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "baseUrl": ".",
        "types": ["node"],
        "maxNodeModuleJsDepth": 0
    },
    "include": [
        "src/**/*.js",
        "src/**/*.d.ts",
        "test/**/*.js",
        "scripts/**/*.js"
    ],
    "exclude": [
        "node_modules",
        "src/editor/**"
    ]
}
